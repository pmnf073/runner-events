{
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/auth/(.*)",
      "dest": "https://runner-events-api.onrender.com/auth/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://runner-events-api.onrender.com/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
